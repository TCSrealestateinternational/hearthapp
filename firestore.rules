rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ──
    function isAuth() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasAgentRole() {
      return isAuth() && 'agent' in getUserData().roles;
    }

    function belongsToBrokerage(brokerageId) {
      return isAuth() && getUserData().brokerageId == brokerageId;
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // Check if user is the client on this transaction, or an agent in the same brokerage
    function canAccessTransaction(transactionId) {
      let tx = get(/databases/$(database)/documents/transactions/$(transactionId)).data;
      return tx.clientId == request.auth.uid ||
             (hasAgentRole() && getUserData().brokerageId == tx.brokerageId);
    }

    // Check if user is a client linked to this agent
    function isLinkedClient(agentId) {
      return isAuth()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(["buyer", "seller"])
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.agentId == agentId;
    }

    // ── Brokerages ──
    match /brokerages/{brokerageId} {
      allow read: if isAuth();
      allow create: if hasAgentRole();
      allow update: if hasAgentRole() && belongsToBrokerage(brokerageId);
    }

    // ── Users (shared between RE Tracker & Hearth) ──
    match /users/{userId} {
      allow read: if isAuth() && (
        request.auth.uid == userId ||
        (hasAgentRole() && resource.data.brokerageId == getUserData().brokerageId)
      );
      allow create: if isAuth() && (
        request.auth.uid == userId ||
        (hasAgentRole() && request.resource.data.brokerageId == getUserData().brokerageId)
      );
      allow update: if isAuth() && (
        request.auth.uid == userId ||
        request.auth.uid == resource.data.agentId
      );
    }

    // ── Legacy User Profiles (kept for backwards compat) ──
    match /userProfiles/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
    }

    // ── Transactions (bridge between RE Tracker deals & Hearth views) ──
    match /transactions/{txId} {
      allow read: if isAuth() && (
        resource.data.clientId == request.auth.uid ||
        resource.data.agentId == request.auth.uid ||
        (hasAgentRole() && belongsToBrokerage(resource.data.brokerageId))
      );
      allow create: if isAuth()
        && request.auth.uid == request.resource.data.agentId;
      allow update: if isAuth() && (
        resource.data.agentId == request.auth.uid ||
        resource.data.clientId == request.auth.uid ||
        (hasAgentRole() && belongsToBrokerage(resource.data.brokerageId))
      );
      allow delete: if hasAgentRole()
        && belongsToBrokerage(resource.data.brokerageId);

      // Milestones subcollection
      match /milestones/{mId} {
        allow read: if isAuth() && (
          hasAgentRole() ||
          (resource.data.clientVisible == true &&
           get(/databases/$(database)/documents/transactions/$(txId)).data.clientId == request.auth.uid)
        );
        allow write: if hasAgentRole();
      }

      // Cost estimates subcollection
      match /costEstimate/{id} {
        allow read: if isAuth() && (
          hasAgentRole() ||
          get(/databases/$(database)/documents/transactions/$(txId)).data.clientId == request.auth.uid
        );
        allow write: if hasAgentRole();
      }

      // Decision log subcollection
      match /decisionLog/{id} {
        allow read: if isAuth() && (
          hasAgentRole() ||
          get(/databases/$(database)/documents/transactions/$(txId)).data.clientId == request.auth.uid
        );
        allow write: if hasAgentRole();
      }
    }

    // ── Client Invites ──
    match /clientInvites/{docId} {
      allow read: if isAuth()
        && (request.auth.uid == resource.data.agentId
            || request.auth.token.email == resource.data.clientEmail);
      allow create: if isAuth()
        && request.auth.uid == request.resource.data.agentId;
      allow update: if isAuth();
    }

    // ── RE Tracker agent-only collections ──
    match /timeEntries/{docId} {
      allow read, write: if isAuth() && request.auth.uid == resource.data.userId;
      allow create: if isAuth() && request.auth.uid == request.resource.data.userId;
    }

    match /clients/{docId} {
      allow read: if isAuth()
        && (request.auth.uid == resource.data.userId
            || isLinkedClient(resource.data.userId));
      allow write: if isAuth() && request.auth.uid == resource.data.userId;
      allow create: if isAuth() && request.auth.uid == request.resource.data.userId;
    }

    match /deals/{docId} {
      allow read: if isAuth()
        && (request.auth.uid == resource.data.userId
            || isLinkedClient(resource.data.userId));
      allow write: if isAuth() && request.auth.uid == resource.data.userId;
      allow create: if isAuth() && request.auth.uid == request.resource.data.userId;
    }

    match /checklists/{docId} {
      allow read: if isAuth()
        && (request.auth.uid == resource.data.userId
            || isLinkedClient(resource.data.userId));
      allow write: if isAuth() && request.auth.uid == resource.data.userId;
      allow create: if isAuth() && request.auth.uid == request.resource.data.userId;
    }

    match /dailyCheckIns/{docId} {
      allow read, write: if isAuth() && request.auth.uid == resource.data.userId;
      allow create: if isAuth() && request.auth.uid == request.resource.data.userId;
    }

    match /incomeGoals/{docId} {
      allow read, write: if isAuth() && request.auth.uid == resource.data.userId;
      allow create: if isAuth() && request.auth.uid == request.resource.data.userId;
    }

    match /referrals/{docId} {
      allow read, write: if isAuth() && request.auth.uid == resource.data.userId;
      allow create: if isAuth() && request.auth.uid == request.resource.data.userId;
    }

    // ── RE Tracker Portal Collections ──
    match /decisions/{docId} {
      allow read: if isAuth()
        && (request.auth.uid == resource.data.agentId
            || isLinkedClient(resource.data.agentId));
      allow create: if isAuth()
        && request.auth.uid == request.resource.data.agentId;
      allow update: if isAuth()
        && (request.auth.uid == resource.data.agentId
            || isLinkedClient(resource.data.agentId));
      allow delete: if isAuth()
        && request.auth.uid == resource.data.agentId;
    }

    match /costBreakdowns/{docId} {
      allow read: if isAuth()
        && (request.auth.uid == resource.data.agentId
            || isLinkedClient(resource.data.agentId));
      allow create: if isAuth()
        && request.auth.uid == request.resource.data.agentId;
      allow update: if isAuth()
        && request.auth.uid == resource.data.agentId;
      allow delete: if isAuth()
        && request.auth.uid == resource.data.agentId;
    }

    match /marketData/{docId} {
      allow read: if isAuth()
        && (request.auth.uid == resource.data.agentId
            || isLinkedClient(resource.data.agentId));
      allow create: if isAuth()
        && request.auth.uid == request.resource.data.agentId;
      allow update: if isAuth()
        && request.auth.uid == resource.data.agentId;
      allow delete: if isAuth()
        && request.auth.uid == resource.data.agentId;
    }

    // ── Hearth Collections ──
    match /properties/{propertyId} {
      allow read: if isAuth() && canAccessTransaction(resource.data.transactionId);
      allow create: if isAuth() && canAccessTransaction(request.resource.data.transactionId);
      allow update, delete: if isAuth() && canAccessTransaction(resource.data.transactionId);
    }

    match /financeScenarios/{scenarioId} {
      allow read: if isAuth() && canAccessTransaction(resource.data.transactionId);
      allow create: if isAuth() && canAccessTransaction(request.resource.data.transactionId);
      allow update, delete: if isAuth() && canAccessTransaction(resource.data.transactionId);
    }

    match /offers/{offerId} {
      allow read: if isAuth() && canAccessTransaction(resource.data.transactionId);
      allow create: if hasAgentRole() && canAccessTransaction(request.resource.data.transactionId);
      allow update: if hasAgentRole() && canAccessTransaction(resource.data.transactionId);
    }

    match /listings/{listingId} {
      allow read: if isAuth() && canAccessTransaction(resource.data.transactionId);
      allow create: if hasAgentRole() && canAccessTransaction(request.resource.data.transactionId);
      allow update: if hasAgentRole() && canAccessTransaction(resource.data.transactionId);
    }

    match /documents/{documentId} {
      allow read: if isAuth() && belongsToBrokerage(resource.data.brokerageId);
      allow create: if isAuth()
        && request.resource.data.uploadedBy == request.auth.uid
        && belongsToBrokerage(request.resource.data.brokerageId);
    }

    // ── Messaging ──
    match /conversations/{docId} {
      allow read: if isAuth()
        && (request.auth.uid == resource.data.agentId
            || request.auth.uid == resource.data.clientUserId);
      allow create: if isAuth();
      allow update: if isAuth()
        && (request.auth.uid == resource.data.agentId
            || request.auth.uid == resource.data.clientUserId);
    }

    match /messages/{messageId} {
      allow read: if isAuth() && (
        resource.data.threadId == request.auth.uid ||
        resource.data.senderId == request.auth.uid ||
        (hasAgentRole() && getUserData().brokerageId == resource.data.brokerageId)
      );
      allow create: if isAuth()
        && request.resource.data.senderId == request.auth.uid;
      allow update: if isAuth() && (
        resource.data.threadId == request.auth.uid ||
        (hasAgentRole() && getUserData().brokerageId == resource.data.brokerageId)
      );
    }

    // ── Glossary ──
    match /glossary/{termId} {
      allow read: if isAuth();
      allow write: if hasAgentRole();
    }
  }
}
