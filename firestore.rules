rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ──
    function isAuth() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAgent() {
      return isAuth() && 'agent' in getUserData().roles;
    }

    function belongsToBrokerage(brokerageId) {
      return isAuth() && getUserData().brokerageId == brokerageId;
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // Check if user is the client on this transaction, or an agent in the same brokerage
    function canAccessTransaction(transactionId) {
      let tx = get(/databases/$(database)/documents/transactions/$(transactionId)).data;
      return tx.clientId == request.auth.uid ||
             ('agent' in getUserData().roles && getUserData().brokerageId == tx.brokerageId);
    }

    // ── Brokerages ──
    match /brokerages/{brokerageId} {
      allow read: if isAuth();
      allow write: if false; // Admin only
    }

    // ── Users (shared between RE Tracker & Hearth) ──
    match /users/{userId} {
      allow read: if isAuth() && (
        request.auth.uid == userId ||
        (isAgent() && resource.data.brokerageId == getUserData().brokerageId)
      );
      allow update: if isAuth() && request.auth.uid == userId;
      allow create: if isAuth() && (
        request.auth.uid == userId ||
        (isAgent() && request.resource.data.brokerageId == getUserData().brokerageId)
      );
    }

    // ── Transactions (bridge between RE Tracker deals & Hearth views) ──
    match /transactions/{txId} {
      allow read: if isAuth() && (
        resource.data.clientId == request.auth.uid ||
        (isAgent() && belongsToBrokerage(resource.data.brokerageId))
      );
      allow create: if isAgent()
        && belongsToBrokerage(request.resource.data.brokerageId);
      allow update: if isAgent()
        && belongsToBrokerage(resource.data.brokerageId);
      allow delete: if isAgent()
        && belongsToBrokerage(resource.data.brokerageId);

      // Milestones subcollection
      match /milestones/{mId} {
        allow read: if isAuth() && (
          isAgent() ||
          (resource.data.clientVisible == true &&
           get(/databases/$(database)/documents/transactions/$(txId)).data.clientId == request.auth.uid)
        );
        allow write: if isAgent();
      }

      // Cost estimates subcollection
      match /costEstimate/{id} {
        allow read: if isAuth() && (
          isAgent() ||
          get(/databases/$(database)/documents/transactions/$(txId)).data.clientId == request.auth.uid
        );
        allow write: if isAgent();
      }

      // Decision log subcollection
      match /decisionLog/{id} {
        allow read: if isAuth() && (
          isAgent() ||
          get(/databases/$(database)/documents/transactions/$(txId)).data.clientId == request.auth.uid
        );
        allow write: if isAgent();
      }
    }

    // ── RE Tracker agent-only collections ──
    match /timeEntries/{docId} {
      allow read, write: if isAuth() && request.auth.uid == resource.data.userId;
      allow create: if isAuth() && request.auth.uid == request.resource.data.userId;
    }

    match /clients/{docId} {
      allow read: if isAuth() && request.auth.uid == resource.data.userId;
      allow write: if isAuth() && request.auth.uid == resource.data.userId;
      allow create: if isAuth() && request.auth.uid == request.resource.data.userId;
    }

    match /deals/{docId} {
      allow read: if isAuth() && request.auth.uid == resource.data.userId;
      allow write: if isAuth() && request.auth.uid == resource.data.userId;
      allow create: if isAuth() && request.auth.uid == request.resource.data.userId;
    }

    match /checklists/{docId} {
      allow read: if isAuth() && request.auth.uid == resource.data.userId;
      allow write: if isAuth() && request.auth.uid == resource.data.userId;
      allow create: if isAuth() && request.auth.uid == request.resource.data.userId;
    }

    match /dailyCheckIns/{docId} {
      allow read, write: if isAuth() && request.auth.uid == resource.data.userId;
      allow create: if isAuth() && request.auth.uid == request.resource.data.userId;
    }

    match /incomeGoals/{docId} {
      allow read, write: if isAuth() && request.auth.uid == resource.data.userId;
      allow create: if isAuth() && request.auth.uid == request.resource.data.userId;
    }

    match /referrals/{docId} {
      allow read, write: if isAuth() && request.auth.uid == resource.data.userId;
      allow create: if isAuth() && request.auth.uid == request.resource.data.userId;
    }

    // ── Hearth collections ──
    match /properties/{propertyId} {
      allow read: if isAuth() && canAccessTransaction(resource.data.transactionId);
      allow create: if isAuth() && canAccessTransaction(request.resource.data.transactionId);
      allow update, delete: if isAuth() && canAccessTransaction(resource.data.transactionId);
    }

    match /financeScenarios/{scenarioId} {
      allow read: if isAuth() && canAccessTransaction(resource.data.transactionId);
      allow create: if isAuth() && canAccessTransaction(request.resource.data.transactionId);
      allow update, delete: if isAuth() && canAccessTransaction(resource.data.transactionId);
    }

    match /offers/{offerId} {
      allow read: if isAuth() && canAccessTransaction(resource.data.transactionId);
      allow create: if isAgent() && canAccessTransaction(request.resource.data.transactionId);
      allow update: if isAgent() && canAccessTransaction(resource.data.transactionId);
    }

    match /listings/{listingId} {
      allow read: if isAuth() && canAccessTransaction(resource.data.transactionId);
      allow create: if isAgent() && canAccessTransaction(request.resource.data.transactionId);
      allow update: if isAgent() && canAccessTransaction(resource.data.transactionId);
    }

    match /messages/{messageId} {
      // Client can read their own thread; agent can read any thread in their brokerage
      allow read: if isAuth() && (
        resource.data.threadId == request.auth.uid ||
        ('agent' in getUserData().roles && getUserData().brokerageId == resource.data.brokerageId)
      );
      // Anyone can send as themselves
      allow create: if isAuth()
        && request.resource.data.senderId == request.auth.uid
        && (
          request.resource.data.threadId == request.auth.uid ||
          ('agent' in getUserData().roles && getUserData().brokerageId == request.resource.data.brokerageId)
        );
      // Read receipts — anyone in the thread can update
      allow update: if isAuth() && (
        resource.data.threadId == request.auth.uid ||
        ('agent' in getUserData().roles && getUserData().brokerageId == resource.data.brokerageId)
      );
    }

    match /documents/{documentId} {
      allow read: if isAuth() && belongsToBrokerage(resource.data.brokerageId);
      allow create: if isAuth()
        && request.resource.data.uploadedBy == request.auth.uid
        && belongsToBrokerage(request.resource.data.brokerageId);
    }

    // ── Glossary ──
    match /glossary/{termId} {
      allow read: if isAuth();
      allow write: if isAgent();
    }
  }
}
