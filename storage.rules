rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /brokerages/{brokerageId}/{allPaths=**} {
      // Authenticated users can read files in their brokerage
      allow read: if request.auth != null;

      // Authenticated users can upload files up to 25MB
      allow write: if request.auth != null
        && request.resource.size < 25 * 1024 * 1024;
    }
  }
}
